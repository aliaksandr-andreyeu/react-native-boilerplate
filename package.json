{
  "name": "react-native-boilerplate",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "watchman:del-all": "watchman watch-del-all",
    "setup": "npm i && cd ios && pod install --repo-update && cd .. && npm run watchman:del-all",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "npm run watchman:del-all && react-native start --reset-cache",
    "test": "jest",
    "android:clean:build": "rimraf ./android/build ./android/app/.cxx ./android/app/build",
    "ios:clean:build": "rimraf ./ios/Podfile.lock ./ios/Pods",
    "android:clean": "npm run android:clean:build && cd android && ./gradlew --stop && ./gradlew clean && ./gradlew generateCodegenArtifactsFromSchema --rerun-tasks",
    "prepare": "husky",
    "precommit": "lint-staged",
    "format": "prettier --write \"./**/*.{js,jsx,cjs,mjs,ts,tsx,json}\"",
    "postinstall": "npx typesync && patch-package"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.10",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-cookies/cookies": "^6.2.1",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/crashlytics": "^24.0.0",
    "@react-native-firebase/remote-config": "^24.0.0",
    "@react-native-vector-icons/icomoon": "12.3.0",
    "@react-native/new-app-screen": "0.85.2",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/devtools": "^7.0.56",
    "@react-navigation/drawer": "^7.9.8",
    "@react-navigation/elements": "^2.9.14",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "@react-navigation/stack": "^7.8.10",
    "@reduxjs/toolkit": "^2.11.2",
    "@sentry/react-native": "^8.9.1",
    "i18next": "^26.0.7",
    "lodash": "^4.18.1",
    "react": "19.2.5",
    "react-hook-form": "^7.73.1",
    "react-i18next": "^17.0.4",
    "react-native": "0.85.2",
    "react-native-bootsplash": "^7.3.1",
    "react-native-device-country": "^2.0.1",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-get-random-values": "^2.0.0",
    "react-native-keyboard-controller": "^1.21.6",
    "react-native-keychain": "^10.0.0",
    "react-native-localize": "^3.7.0",
    "react-native-orientation-locker": "^1.7.0",
    "react-native-reanimated": "^4.3.0",
    "react-native-restart": "^0.0.27",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.4",
    "react-native-tracking-transparency": "^0.1.2",
    "react-native-worklets": "^0.8.1",
    "react-redux": "^9.2.0",
    "text-encoding": "^0.7.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.3",
    "@react-native-community/cli-platform-android": "20.1.3",
    "@react-native-community/cli-platform-ios": "20.1.3",
    "@react-native/babel-preset": "0.85.2",
    "@react-native/eslint-config": "0.85.2",
    "@react-native/jest-preset": "0.85.2",
    "@react-native/metro-config": "0.85.2",
    "@react-native/typescript-config": "0.85.2",
    "@types/babel__core": "~7.20.5",
    "@types/babel__preset-env": "~7.10.0",
    "@types/eslint": "~9.6.1",
    "@types/jest": "^30.0.0",
    "@types/lodash": "~4.17.24",
    "@types/react": "^19.2.0",
    "@types/react-native-get-random-values": "~1.8.2",
    "@types/react-native-vector-icons": "~6.4.18",
    "@types/react-test-renderer": "^19.1.0",
    "@types/text-encoding": "~0.0.40",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "patch-package": "^8.0.1",
    "prettier": "2.8.8",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "19.2.5",
    "reactotron-react-native": "^5.1.18",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typesync": "^0.14.3"
  },
  "engines": {
    "node": ">= 22.13.0"
  }
}
